# === Core (required for API and all pipelines) ===
DATABASE_URL=postgresql+psycopg2://oracle:oracle_dev_password@localhost:5433/oracle
JWT_SECRET=change-me-use-openssl-rand-base64-48
INTERNAL_API_SECRET=change-me-use-openssl-rand-base64-48
GCS_BUCKET=your-project-oracle-signals

# === Oracle API URLs ===
ORACLE_API_BASE=http://localhost:8000   # used by pipelines + Telegram bot
ORACLE_API_URL=http://localhost:8000    # used by Next.js web (proxied to /api/*)

# === Pipeline flags ===
WEEKLY_DRY_RUN=true        # set false to execute live broker trades (real money!)
OPTIONS_DRY_RUN=true       # set false to send iOS push + Telegram notifications

# === AI (Claude) ===
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Moomoo (Futu) — US stocks ===
# Requires Moomoo OpenD daemon running on your Mac.
# Download from: https://www.moomoo.com/openapi/ (free, runs in system tray)
# Log in to OpenD with your Moomoo account. It listens on 127.0.0.1:11111 by default.
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_TRADE_ENV=SIMULATE    # SIMULATE (paper trading, safe) or REAL
MOOMOO_UNLOCK_PWD=           # your Moomoo trading password (only needed for REAL mode)
MOOMOO_MARKET=US             # US or HK

# === CTBC Win168 (中信證券) — Taiwan stocks ===
# Browser automation via Playwright — no API key needed, uses your web login.
# CAPTCHA is solved automatically (ddddocr). Set CTBC_HEADLESS=false to watch the browser.
# Orders are DRY-RUN by default. Set CTBC_DRY_RUN=false to submit real orders.
CTBC_ID=            # 身分證字號 (e.g. A123456789)
CTBC_PASSWORD=      # 登入密碼
CTBC_HEADLESS=true  # false = show browser window (useful for debugging)
CTBC_DRY_RUN=true   # false = actually submit orders (⚠️ real money)

# === Web Trading Page ===
# Must match INTERNAL_API_SECRET — used by the /trading web page to auth broker API calls
NEXT_PUBLIC_INTERNAL_SECRET=same-as-INTERNAL_API_SECRET

# === Google / Apple Auth (optional) ===
GOOGLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
