# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === IBKR (Interactive Brokers) ===
# Requires TWS or IB Gateway running on the host.
# Enable API: TWS → File → Global Configuration → API → Settings → Enable ActiveX and Socket Clients
# IBKR_PORT=7497   # paper-trading TWS
# IBKR_PORT=7496   # live TWS
# IBKR_PORT=4002   # live IB Gateway
IBKR_HOST=127.0.0.1
IBKR_PORT=
IBKR_CLIENT_ID=1

# === Moomoo (Futu) ===
# Requires OpenD daemon running on the host.
# Download: https://www.futunn.com/download/OpenAPI
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=
MOOMOO_TRADE_ENV=SIMULATE    # SIMULATE or REAL
MOOMOO_UNLOCK_PWD=           # trading password (for REAL mode order queries)
MOOMOO_MARKET=US             # US or HK

# === Robinhood ===
# No local daemon needed — REST API only.
# MFA: if enabled, robin_stocks will prompt once, then cache the token.
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
